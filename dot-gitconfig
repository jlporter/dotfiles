[core]
	excludesfile = ~/dotfiles/gitignore
	autocrlf = input
[alias]
	co = checkout
	ci = commit
	br = branch
	d = difftool
[color]
	ui = true
[merge]
	tool = gvimdiff
[push]
	default = simple
[diff]
	tool = vimdiff
[difftool]
	prompt = false
[http]
	cookiefile = /usr/local/google/home/jud/.gitcookies
[pull]
	rebase = true
# Usee SSH when pulling from github. Because of 2fa, passwords over https are not supported.
[url "git@github.com:"]
     pushInsteadOf = "https://github.com/"
[credential "https://dev.azure.com"]
	useHttpPath = true
